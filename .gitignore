.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
*.tmp

# Temporary files
*.log
*.out
*.err

# Local data directories (if creating locally)
data/
scratch/

# Dask worker directories
dask-worker-space/

# Environment files (optional - uncomment if needed)
# venv/
